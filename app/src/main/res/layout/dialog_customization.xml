<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_bg"
    android:backgroundTint="@color/background_card"
    android:clipToPadding="false"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Personalizza lo Stile"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- selettore foto profilo -->
    <FrameLayout
        android:id="@+id/dialog_btn_pick_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true">

        <!-- contenitore avatar ritagliato -->
        <FrameLayout
            android:id="@+id/dialog_profile_image_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/dialog_iv_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="@color/text_secondary"
                app:shapeAppearanceOverlay="@style/CircleImageView" />
        </FrameLayout>

        <!-- badge per la modifica della foto -->
        <FrameLayout
            android:id="@+id/dialog_badge_container"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_shape"
            android:backgroundTint="@color/accent_color"
            android:elevation="2dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/background_color" />
        </FrameLayout>
    </FrameLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/dialog_name_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:hint="Il tuo Nome"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
        app:startIconTint="@color/text_secondary"
        app:boxStrokeColor="@color/accent_color"
        app:hintTextColor="@color/accent_color"
        app:boxCornerRadiusTopStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusBottomEnd="16dp"
        android:textColorHint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/dialog_api_key_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Chiave API Gemini (opzionale)"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:startIconDrawable="@drawable/ic_key"
        app:startIconTint="@color/text_secondary"
        app:boxStrokeColor="@color/accent_color"
        app:hintTextColor="@color/accent_color"
        app:boxCornerRadiusTopStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusBottomEnd="16dp"
        android:textColorHint="@color/text_secondary"
        app:endIconMode="password_toggle"
        app:endIconTint="@color/text_secondary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialog_et_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/white"
            android:inputType="textPassword"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleziona Tavolozza Colori"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:id="@+id/dialog_layout_themes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp"/>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Annulla"
            android:textColor="@color/text_secondary"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dialog_btn_apply"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/accent_color"
            android:text="Salva e Applica"
            android:textAllCaps="false"
            android:textColor="@color/background_color"
            android:textStyle="bold"
            android:paddingHorizontal="24dp"
            android:stateListAnimator="@null"
            app:cornerRadius="24dp"
            style="@style/Widget.Material3.Button"/>
    </LinearLayout>

</LinearLayout>
