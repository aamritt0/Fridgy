<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- schermata iniziale di splash -->
    <LinearLayout
        android:id="@+id/layout_splash"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background_color">

        <!-- contenitore foto nella metà superiore -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.1">

            <ImageView
                android:id="@+id/hero_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/welcome_food"
                android:scaleType="centerCrop" />

            <!-- sfumatura scura sul fondo dell'immagine -->
            <View
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom" />
        </FrameLayout>

        <!-- contenuto in basso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="56dp"
            android:paddingTop="24dp">

            <TextView
                android:id="@+id/hero_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Il cibo sano&#10;è buoooono"
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:text="Più di 10.000 ricette per ogni giorno e gusto"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:lineSpacingMultiplier="1.2" />

            <!-- segnaposto per compatibilità layout -->
            <FrameLayout
                android:id="@+id/hero_image_container"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_get_started"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:backgroundTint="@color/accent_color"
                app:cornerRadius="32dp"
                android:stateListAnimator="@null"
                android:text="Iniziamo"
                android:textAllCaps="false"
                android:textColor="@color/background_color"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- schermata impostazione profilo -->
    <LinearLayout
        android:id="@+id/layout_profile_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="32dp"
        android:gravity="center">

        <!-- titolo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura il tuo Profilo"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dicci come ti chiami e scegli una foto!"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <!-- selettore immagine profilo -->
        <FrameLayout
            android:id="@+id/btn_pick_image"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true">

            <!-- contenitore per l'avatar ritagliato -->
            <FrameLayout
                android:id="@+id/setup_profile_image_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/setup_iv_profile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/text_secondary"
                    app:shapeAppearanceOverlay="@style/CircleImageView" />
            </FrameLayout>

            <!-- badge per la modifica della foto -->
            <FrameLayout
                android:id="@+id/setup_badge_container"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/circle_shape"
                android:backgroundTint="@color/accent_color"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/background_color" />
            </FrameLayout>
        </FrameLayout>

        <!-- inserimento nome utente -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/setup_name_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="Il tuo nome..."
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="@color/text_secondary"
            app:boxStrokeColor="@color/accent_color"
            app:hintTextColor="@color/accent_color"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            android:textColorHint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/setup_et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textColor="@color/white"
                android:inputType="textPersonName|textCapSentences"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- selettore del tema di colore -->
        <TextView
            android:id="@+id/setup_tv_palette_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleziona Tavolozza Colori"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="start"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/setup_layout_themes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp"/>
        </HorizontalScrollView>

        <!-- pulsante di conferma -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_setup"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/accent_color"
            app:cornerRadius="32dp"
            android:stateListAnimator="@null"
            android:text="Continua"
            android:textAllCaps="false"
            android:textColor="@color/background_color"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- schermata configurazione chiave api -->
    <LinearLayout
        android:id="@+id/layout_api_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="32dp"
        android:gravity="center">

        <!-- titolo -->
        <TextView
            android:id="@+id/setup_api_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura l'IA"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fridgy genera ricette con l'Intelligenza Artificiale. Per iniziare, inserisci la tua API Key di Gemini."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- inserimento chiave api -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/setup_api_key_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="API Key di Gemini..."
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            app:startIconDrawable="@drawable/ic_key"
            app:startIconTint="@color/text_secondary"
            app:boxStrokeColor="@color/accent_color"
            app:hintTextColor="@color/accent_color"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            android:textColorHint="@color/text_secondary"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/setup_et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:textColor="@color/white"
                android:inputType="textPassword"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- scheda informativa per ottenere la chiave api -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:backgroundTint="@color/background_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/setup_api_tutorial_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COME OTTENERE LA CHIAVE API"
                android:textColor="@color/accent_color"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Vai su Google AI Studio."
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Accedi con il tuo account Google."
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Clicca su 'Get API key' e creane una nuova."
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/btn_get_api_key_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Ottieni una chiave API gratis"
                android:textColor="@color/accent_color"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:padding="8dp" />
        </LinearLayout>

        <!-- pulsante di conferma -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_finish_setup"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:backgroundTint="@color/accent_color"
            app:cornerRadius="32dp"
            android:stateListAnimator="@null"
            android:text="Inizia l'avventura!"
            android:textAllCaps="false"
            android:textColor="@color/background_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- pulsante per saltare la configurazione api -->
        <TextView
            android:id="@+id/btn_skip_api_key"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configura più tardi"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp" />

    </LinearLayout>

</FrameLayout>
